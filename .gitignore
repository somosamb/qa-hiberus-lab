# Virtual environment — never commit this folder
.venv/

# pytest cache — generated automatically during test runs
.pytest_cache/

# Python bytecode cache
__pycache__/
*.pyc

# Test reports — generated output, not source code
reports/
resources/

# Playwright browser binaries — too large for a repo, installed via CLI
playwright-browsers/

# Private AI agent notes — not for version control
Memories.md

# OS files
.DS_Store
Thumbs.db
